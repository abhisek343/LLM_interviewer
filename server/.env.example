# LLM Interviewer Backend Environment Variables (.env.example)
# Copy this file to .env and fill in your actual values.
# Do NOT commit your actual .env file to version control.

# --- Core App Settings ---
APP_NAME="LLM Interviewer"
DEBUG=False # Set to True for development debugging (enables more verbose errors)

# --- MongoDB Connection ---
MONGODB_URL="mongodb://localhost:27017" # Your MongoDB connection string
MONGODB_DB="llm_interview_db"          # The database name to use

# --- MongoDB Collection Names (Optional - uses defaults from config.py if not set) ---
# MONGODB_COLLECTION_USERS="users"
# MONGODB_COLLECTION_INTERVIEWS="interviews"
# MONGODB_COLLECTION_RESPONSES="responses"
# MONGODB_COLLECTION_QUESTIONS="questions"

# --- JWT Configuration ---
# ** IMPORTANT: Generate a strong, random secret key! **
# You can generate one using: openssl rand -hex 32
JWT_SECRET_KEY="your_strong_random_secret_key_please_change_me"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60 # How long access tokens are valid (in minutes)

# --- CORS Settings ---
# Comma-separated list of allowed origins for frontend access
# Example: CORS_ALLOWED_ORIGINS_STR="http://localhost:5173,http://your-frontend-domain.com"
# If not set, defaults to ["http://localhost:3000", "http://localhost:5173"] specified in config.py
# CORS_ALLOWED_ORIGINS_STR="http://localhost:5173,http://localhost:3000"

# --- Google Gemini API ---
GEMINI_API_KEY="your_google_gemini_api_key_here" # ** REQUIRED ** Obtain from Google AI Studio
# Optional: Specify the Gemini model name (defaults to 'gemini-1.5-flash' in config.py)
# GEMINI_MODEL_NAME="gemini-1.5-pro"

# --- File Upload Settings ---
# Directory where uploaded resumes will be stored (relative to server root)
RESUME_UPLOAD_DIR="uploads/resumes"
# Allowed resume extensions (JSON formatted string, e.g., '["pdf","docx","doc"]')
# If not set, defaults to [".pdf", ".docx"] specified in config.py
# ALLOWED_RESUME_EXTENSIONS_JSON='["pdf", "docx"]'

# --- Evaluation Settings ---
# Score range used for validation and potentially UI hints
EVALUATION_SCORE_MIN=0.0
EVALUATION_SCORE_MAX=5.0

# --- Optional: Default Admin User Seeding ---
# If these are set, an admin user will be created on startup if one doesn't exist with this email.
# DEFAULT_ADMIN_EMAIL=admin@example.com
# DEFAULT_ADMIN_USERNAME=adminuser
# DEFAULT_ADMIN_PASSWORD=your_secure_admin_password